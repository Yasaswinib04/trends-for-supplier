# DeepSeek API key — get yours from https://platform.deepseek.com/api_keys
# Copy this file to .env and paste your key:
DEEPSEEK_API_KEY=sk-your-key-here

# YouTube Data API v3 key — get yours from https://console.cloud.google.com/apis/credentials
# Used by signals/social_bridge.py for Kurti haul video parsing
# App works without it (falls back to cached social data)
YOUTUBE_API_KEY=your-youtube-api-key-here

# Google Shopping API key (SearchAPI.io) — get yours from https://www.searchapi.io
# 100 free searches/month. Used by sources/google_shopping.py for
# live price comparison across retailers on Google Shopping.
# App works without it (falls back to cached marketplace data)
GOOGLE_SHOPPING_API_KEY=your-searchapi-key-here

# Rainforest API key — get yours from https://rainforestapi.com
# Used by sources/rainforest.py for live Amazon.in product data
# (prices, ratings, discounts, stock, sponsored flags).
# App works without it (falls back to cached marketplace data)
RAPIDAPI_KEY=your-rainforest-key-here
