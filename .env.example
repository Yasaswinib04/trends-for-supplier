# DeepSeek API key — get yours from https://platform.deepseek.com/api_keys
# Copy this file to .env and paste your key:
DEEPSEEK_API_KEY=sk-your-key-here

# YouTube Data API v3 key — get yours from https://console.cloud.google.com/apis/credentials
# Used by signals/social_bridge.py for Kurti haul video parsing
# App works without it (falls back to cached social data)
YOUTUBE_API_KEY=your-youtube-api-key-here
